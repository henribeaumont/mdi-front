{
  "manifest_version": 3,
  "name": "MDI Live Watchtower",
  "version": "2.3",
  "description": "Connecte le chat Zoom, Meet, Teams et WebinarJam aux overlays MDI Live en temps réel.",
  "homepage_url": "https://henri-beaumont.com",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://magic-digital-impact-live.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zoom.us/*",
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://*.webinarjam.com/*",
        "https://*.everwebinar.com/*"
      ],
      "js": ["socket.io.js", "content.js"],
      "all_frames": true
    }
  ]
}
